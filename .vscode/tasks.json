{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "serve",
            "dependsOn": [
                "netlify dev",
                "jekyll: serve"
            ],
            "problemMatcher": []
        },
        {
            "label": "netlify dev",
            "type": "shell",
            "command": "netlify dev --no-open",
            "options": {
                "env": {
                    "CHOKIDAR_USEPOLLING": "1"
                }
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "jekyll: serve",
            "type": "shell",
            "command": "bundle exec jekyll serve --incremental --port 4003",
            "isBackground": true,
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": true,
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "bundle: install",
            "type": "shell",
            "command": "bundle install"
        },
        {
            "label": "bundle: update",
            "type": "shell",
            "command": "bundle update"
        },
        {
            "label": "jekyll: build",
            "type": "shell",
            "command": "bundle exec jekyll build",
            "problemMatcher": []
        }
    ]
}
